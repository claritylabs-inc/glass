# Glass iMessage worker local development template.
# Copy to .env.local and fill in live dev values.
#
# Run with either:
#   set -a; source .env.local; set +a; npm run dev:terminal
# or:
#   npm run build && node --env-file=.env.local dist/index.js

# Dev terminal TUI transport. Keep real Photon iMessage disabled in dev.
IMESSAGE_ENABLED=false
SPECTRUM_PROVIDER=terminal

# Convex dev HTTP actions URL.
CONVEX_SITE_URL=https://your-dev-deployment.convex.site

# Must match IMESSAGE_WORKER_SECRET in the Convex dev environment.
IMESSAGE_WORKER_SECRET=change-me

# Must match a Glass user phone in Convex dev so inbound messages can route.
IMESSAGE_TERMINAL_FROM_PHONE=+15555550123
IMESSAGE_TERMINAL_SPACE_ID=chat-1

# Local outbound HTTP server used by Convex status-cue sends.
WORKER_HTTP_PORT=3001

# Required only for SPECTRUM_PROVIDER=imessage / production-like real iMessage.
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=
