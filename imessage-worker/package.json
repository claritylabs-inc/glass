{
  "name": "@glass/imessage-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Glass iMessage worker — bridges Photon Spectrum to Convex",
  "packageManager": "npm@11.12.1",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:terminal": "SPECTRUM_PROVIDER=terminal IMESSAGE_ENABLED=false node dist/index.js",
    "dev:terminal": "npm run build && npm run start:terminal"
  },
  "dependencies": {
    "@spectrum-ts/imessage": "^5.0.0",
    "@spectrum-ts/terminal": "^5.0.0",
    "spectrum-ts": "^5.0.0"
  },
  "overrides": {
    "@opentelemetry/api-logs": "0.219.0",
    "@opentelemetry/context-async-hooks": "2.8.0",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/otlp-exporter-base": "0.219.0",
    "@opentelemetry/otlp-transformer": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-logs": "0.219.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-trace-base": "2.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
