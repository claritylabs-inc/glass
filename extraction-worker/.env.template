# Convex client URL, not the HTTP actions site URL.
# Example: https://acoustic-caiman-755.convex.cloud
CONVEX_URL=

# Must match EXTRACTION_WORKER_SECRET in the Convex deployment.
EXTRACTION_WORKER_SECRET=

# Set on the Convex deployment to route newly-started/retried extractions here.
# EXTRACTION_WORKER_MODE=external

# Provider keys used by Glass model routing defaults.
OPENAI_API_KEY=
MOONSHOTAI_API_KEY=
MOONSHOT_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Optional tuning.
EXTRACTION_WORKER_ID=railway-extraction-worker
EXTRACTION_WORKER_POLL_MS=5000
EXTRACTION_WORKER_IDLE_LOG_MS=60000
EXTRACTION_WORKER_HEARTBEAT_MS=30000

# Optional HTTP endpoint for Convex actions that need synchronous PDF-to-Docling conversion.
# Railway provides PORT automatically. Set EXTRACTION_WORKER_URL on Convex to this service URL.
# DOCLING_HTTP_PORT=8787
DOCLING_CONVERT_TIMEOUT_MS=120000
DOCLING_HTTP_MAX_BODY_BYTES=52428800
# DOCLING_MAX_PAGES=
# DOCLING_MAX_FILE_SIZE_BYTES=

EXTRACTION_CONCURRENCY=8
EXTRACTION_PAGE_MAP_CONCURRENCY=8
EXTRACTION_EXTRACTOR_CONCURRENCY=8
EXTRACTION_FORMAT_CONCURRENCY=8
EXTRACTION_MAX_REVIEW_ROUNDS=1
EXTRACTION_REVIEW_MODE=auto
