# Convex client URL, not the HTTP actions site URL.
# Example: https://acoustic-caiman-755.convex.cloud
CONVEX_URL=

GLASS_ENV=local

# Must match EXTRACTION_WORKER_SECRET in the Convex deployment.
EXTRACTION_WORKER_SECRET=

# Set on the Convex deployment to route newly-started/retried extractions here.
# EXTRACTION_WORKER_MODE=external

# Provider keys used by Glass model routing defaults.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Optional tuning.
EXTRACTION_WORKER_ID=railway-extraction-worker
# Sent to Convex on every job claim. Convex rejects workers whose protocol does
# not match EXTRACTION_WORKER_EXPECTED_PROTOCOL_VERSION.
# EXTRACTION_WORKER_VERSION=
# EXTRACTION_WORKER_CL_SDK_VERSION=
EXTRACTION_WORKER_POLL_MS=5000
EXTRACTION_WORKER_IDLE_LOG_MS=60000
EXTRACTION_WORKER_HEARTBEAT_MS=30000

# Optional HTTP endpoint for Convex actions that need synchronous LiteParse PDF conversion.
# Railway provides PORT automatically. Set EXTRACTION_WORKER_URL on Convex to this service URL.
# LITEPARSE_HTTP_PORT=8787
LITEPARSE_CONVERT_TIMEOUT_MS=120000
LITEPARSE_HTTP_MAX_BODY_BYTES=52428800
# LITEPARSE_MAX_PAGES=
# LITEPARSE_MAX_FILE_SIZE_BYTES=
LITEPARSE_OCR_ENABLED=false
LITEPARSE_OCR_LANGUAGE=eng
LITEPARSE_DPI=150
LITEPARSE_NUM_WORKERS=4
LITEPARSE_SCREENSHOT_MAX_PAGES=12
EXTRACTION_MULTIMODAL_MAX_IMAGES=2
